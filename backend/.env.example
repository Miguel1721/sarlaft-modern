# Base de Datos
DATABASE_URL=postgresql://user:password@host:5432/database

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CAPTCHA_SOLVER_API_KEY=your_2captcha_api_key_here
CAPTCHA_SOLVER_PROVIDER=2captcha

# Configuración SMTP para Notificaciones por Email
# Obligatorio para que funcionen las notificaciones

# Opción 1: Gmail (recomendado para testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion_gmail
FROM_EMAIL=noreply@sarlaf.agentesia.cloud
FROM_NAME=SARLAFT 4.0 - Sistema de Debida Diligencia

# Opción 2: SendGrid (recomendado para producción)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your_sendgrid_api_key_here
# FROM_EMAIL=noreply@sarlaf.agentesia.cloud
# FROM_NAME=SARLAFT 4.0

# Opción 3: AWS SES (recomendado para alto volumen)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_aws_ses_smtp_username
# SMTP_PASSWORD=your_aws_ses_smtp_password
# FROM_EMAIL=noreply@sarlaf.agentesia.cloud
# FROM_NAME=SARLAFT 4.0

# Opción 4: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your_domain.mailgun.org
# SMTP_PASSWORD=your_mailgun_password
# FROM_EMAIL=noreply@sarlaf.agentesia.cloud
# FROM_NAME=SARLAFT 4.0

# NOTA: Para Gmail necesitas crear una "Contraseña de aplicación"
# Ve a: https://myaccount.google.com/apppasswords
# 1. Inicia sesión en tu cuenta de Google
# 2. Selecciona "Seguridad"
# 3. En "Contraseñas de aplicaciones", haz clic en la flecha
# 4. Selecciona "Mail" y "Computadora"
# 5. Sigue las instrucciones para generar la contraseña
